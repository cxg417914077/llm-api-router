# Router 自身配置
router:
  api_key: "sk-your-router-key"

# 服务器配置
server:
  host: "0.0.0.0"
  port: 8080

# Provider 组定义
groups:
  production:
    failover:
      failure_threshold: 3
      recovery_timeout: 60
    providers:
      - name: "primary"
        endpoint: "https://api.openai.com/v1"
        api_key: "${OPENAI_API_KEY}"
        priority: 1
        ssl_verify: true

      - name: "local-ollama"
        endpoint: "http://localhost:8000/v1"
        api_key: "not-needed"
        priority: 2
        ssl_verify: false
